APP_NAME="Brasfoot 2026"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seu-app.up.railway.app

# Railway injeta estas variáveis ao adicionar o plugin PostgreSQL.
# Use as referências ${{Postgres.PGHOST}} etc. nas Variables do serviço.
DB_CONNECTION=pgsql
DB_HOST=${PGHOST}
DB_PORT=${PGPORT}
DB_DATABASE=${PGDATABASE}
DB_USERNAME=${PGUSER}
DB_PASSWORD=${PGPASSWORD}

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# Você já usa Sentry — opcional:
# SENTRY_LARAVEL_DSN=
