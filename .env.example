APP_NAME="Brasfoot 2026"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Local: SQLite (mais simples). Crie o arquivo: touch database/database.sqlite
DB_CONNECTION=sqlite
# DB_DATABASE=/caminho/absoluto/opcional/database.sqlite

SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# Para produção no Railway (PostgreSQL), veja .env.railway.example
